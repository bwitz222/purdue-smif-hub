# Environment variables for Purdue SMIF Hub.
# Copy to .env for local dev. In production these are set in the Vercel
# dashboard (Project → Settings → Environment Variables), NOT committed.

# --- Supabase (server-side) ---
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_PROJECT_ID="<project-ref>"
# anon/publishable key. Public by design (also exposed to the browser via the
# VITE_ vars below). Used for the auth-middleware bearer-token path only.
SUPABASE_PUBLISHABLE_KEY="<supabase-publishable-or-anon-key>"
# service-role key — used by src/integrations/supabase/client.server.ts for
# writes (quote_cache, benchmark_monthly). Server-only; never expose to client.
SUPABASE_SERVICE_ROLE_KEY="<supabase-service-role-key>"

# --- Supabase (client / Vite-exposed) ---
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PROJECT_ID="<project-ref>"
VITE_SUPABASE_PUBLISHABLE_KEY="<supabase-publishable-or-anon-key>"

# --- Hook auth (refresh-quotes + compute-risk) ---
# Dedicated server-only secret gating POST /api/public/hooks/refresh-quotes and
# /api/public/hooks/compute-risk (the daily quote + portfolio risk jobs).
# Do NOT reuse the publishable/anon key here — that value is public. Generate a
# high-entropy random string (e.g. `openssl rand -hex 32`). Both pg_cron jobs
# must send this exact value in the `x-refresh-secret` header (see
# supabase/repoint-refresh-quotes-cron.sql and supabase/compute-risk-cron.sql).
REFRESH_HOOK_SECRET="<random-server-only-secret>"

# --- Market data providers ---
# Polygon.io grouped daily bars -> quote_cache (refresh-quotes hook) and daily
# closes -> price_history (compute-risk hook). Free tier is 5 req/min.
POLYGON_API_KEY="<polygon-api-key>"
# Alpha Vantage: SPY monthly benchmark (refresh-quotes) AND the live 3-month
# Treasury yield used as the risk-free rate in the Sharpe ratio (compute-risk).
ALPHA_VANTAGE_API_KEY="<alpha-vantage-api-key>"

# NOTE: SUPABASE_SERVICE_ROLE_KEY must be the current mxjr sb_secret_ key
# (new-gen keys rotate; a stale value fails server fns with "Invalid API key").
